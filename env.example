# Copier ce fichier en ".env" (non versionné) et ajuster si besoin.
# Les valeurs par défaut ci-dessous sont des valeurs de DEV uniquement.

# --- Postgres ---
POSTGRES_DB=deezerstats
POSTGRES_USER=deezerstats
POSTGRES_PASSWORD=deezerstats_dev_only
POSTGRES_PORT=5432

# --- Meilisearch ---
MEILI_MASTER_KEY=dev_master_key_change_me
MEILISEARCH_PORT=7700

# --- Api ---
API_PORT=5231
JWT_SECRET=dev_only_change_me_in_every_other_environment

# --- Frontend ---
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:5231/api/v1
